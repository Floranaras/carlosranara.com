/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/public/screenshots/*
  Cache-Control: public, max-age=31536000, immutable

/robots.txt
  Content-Type: text/plain
  Cache-Control: public, max-age=86400

/sitemap.xml
  Content-Type: application/xml
  Cache-Control: public, max-age=86400

/favicon.ico
  Content-Type: image/x-icon
  Cache-Control: public, max-age=86400

/CV.pdf
  Content-Type: application/pdf
  Cache-Control: public, max-age=86400
